# Copy to .env and fill in. Never commit real secrets.

# GitHub Models — https://github.com/settings/tokens (fine-grained PAT with Models: Read)
GITHUB_TOKEN=

# OpenRouter fallback — https://openrouter.ai/keys (no card needed for free models)
OPENROUTER_API_KEY=

# GitHub OAuth App — https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Generate with: npx auth secret
AUTH_SECRET=

# Vercel Postgres / Neon
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
